# =============================================================================
# MediaFlow — Environment Variables Template
#
# Copy this file to .env before starting the project:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set before `docker compose up`.
# Variables marked [DEFAULT OK] are safe to leave unchanged for local dev.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=MediaFlow
APP_ENV=local                          # [DEFAULT OK] local | production
APP_KEY=                               # [REQUIRED] Generate with: php artisan key:generate
APP_DEBUG=true                         # [DEFAULT OK] Set false in production
APP_URL=http://localhost               # [DEFAULT OK] Public URL of the application
APP_PORT=80                            # [DEFAULT OK] Host port mapped to nginx

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                        # [DEFAULT OK] Set to `error` in production

# -----------------------------------------------------------------------------
# Database (MySQL 8.4)
# DB_HOST must match the compose service name — do not change.
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql                          # [DEFAULT OK] Docker service name
DB_PORT=3306
DB_DATABASE=mediaflow                  # [DEFAULT OK]
DB_USERNAME=mediaflow                  # [DEFAULT OK]
DB_PASSWORD=secret                     # [REQUIRED] Change before any shared deployment
FORWARD_DB_PORT=3306                   # [DEFAULT OK] Host port for direct DB access

# -----------------------------------------------------------------------------
# Session
# Using Redis keeps sessions consistent across multiple app replicas.
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Queue
# MUST remain `redis` — Laravel Horizon requires a Redis queue driver.
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_STORE=redis

# -----------------------------------------------------------------------------
# Redis (7.2)
# REDIS_HOST must match the compose service name — do not change.
# REDIS_CLIENT=phpredis requires the phpredis extension (installed in Dockerfile).
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis                       # [DEFAULT OK] Docker service name
REDIS_PASSWORD=null
REDIS_PORT=6379
FORWARD_REDIS_PORT=6379                # [DEFAULT OK] Host port for direct Redis access

# -----------------------------------------------------------------------------
# Broadcasting — Soketi (Pusher-protocol WebSocket server)
# BROADCAST_CONNECTION must remain `pusher` — Soketi speaks the Pusher protocol.
# PUSHER_HOST must match the compose service name for server-side publishing.
# Browser clients connect on PUSHER_PORT via Laravel Echo.
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=mediaflow-app-id         # [DEFAULT OK] Must match SOKETI_DEFAULT_APP_ID
PUSHER_APP_KEY=mediaflow-app-key       # [DEFAULT OK] Must match SOKETI_DEFAULT_APP_KEY
PUSHER_APP_SECRET=mediaflow-app-secret # [REQUIRED] Change before any shared deployment
PUSHER_HOST=soketi                     # [DEFAULT OK] Docker service name
PUSHER_PORT=6001                       # [DEFAULT OK] Soketi WebSocket port
PUSHER_SCHEME=http                     # [DEFAULT OK] No TLS in local dev
PUSHER_APP_CLUSTER=mt1                 # [DEFAULT OK] Required by Echo client; value is ignored by Soketi

# Soketi service ports
SOKETI_PORT=6001                       # [DEFAULT OK] WebSocket port mapped to host
SOKETI_METRICS_PORT=9601               # [DEFAULT OK] Prometheus metrics port
SOKETI_DEBUG=0                         # [DEFAULT OK] Set to 1 for verbose WS logging

# -----------------------------------------------------------------------------
# Filesystem
# All media files are stored on the local filesystem — no S3/cloud in scope.
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Laravel Horizon
# HORIZON_ADMIN_EMAIL controls who can access the /horizon dashboard.
# Only this email address (when authenticated) will pass the Horizon auth gate.
# Must match the seeded demo user's email in Phase 6.
# See: app/Providers/HorizonServiceProvider.php
# -----------------------------------------------------------------------------
HORIZON_ADMIN_EMAIL=admin@mediaflow.test

# -----------------------------------------------------------------------------
# Mail (log driver — no real email sent in local dev)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@mediaflow.test"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Vite (frontend asset compilation)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
